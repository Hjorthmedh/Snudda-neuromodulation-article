{
    "network_path": "networks/mod",
    "network_file": "$network_path/network-synapses.hdf5",
    "output_file": "$network_path/simulation/output.hdf5",
    "log_file": "$network_path/log/network-simulation.txt",
    "time": 1.0,
    "sim_dt": 0.00005,
    "sample_dt": 1e-3,
    "record_all_soma": true,
    "use_rxd_neuromodulation": true,

    "record_density_mechanism": {
        "Nair_2016_optimized.DA":              {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.D1R_Golf_DA":     {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.GaolfGTP":        {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.AC5_Ca_GaolfGTP": {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.cAMP":            {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.PKAc":            {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.PKAc_D32":        {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.D32p34":          {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.PP1_pSubstrate":  {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.pSubstrate":      {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.CaMKII":          {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "Nair_2016_optimized.pCaMKII":         {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "sk_ms.modulation_factor":      {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]},
        "naf_ms.modulation_factor":     {"neuron_id": [0], "section_id": [-1], "section_x": [0.5]}
    },

    "record_membrane": [
        {"neuron_id": 0, "variable": "cali", "sec_id": -1, "sec_x": 0.5}
    ],

    "bath_application": {
        "DA": {
            "neuron_id": [0],
            "time":          [0.0,  0.01,   0.1],
            "concentration": [0.0,  6e-4,  6e-4],
            "interpolate": true
        }
    }
}
